# SMTP Configuration for Email Service
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
# For other providers: Use your SMTP credentials

# Local Docker databases (Postgres + MongoDB)
# Auth service (Postgres container)
AUTH_SERVICE_DB_URL=jdbc:postgresql://postgres-auth:5432/okkazo_auth_db
AUTH_SERVICE_DB_USERNAME=postgres
AUTH_SERVICE_DB_PASSWORD=root

# MongoDB Docker URIs (use one database per service)
USER_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_user_db
VENDOR_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_vendor_db
CHAT_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_chat_db
ADMIN_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_admin_db
EVENT_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_event_db
ORDER_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_order_db
NOTIFICATION_SERVICE_MONGODB_URI=mongodb://mongodb:27017/okkazo_notification_db

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@okkazo.com

# Frontend URLs used by gateway/chat CORS and service links
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_FALLBACK=http://localhost:3000
VERIFICATION_URL=http://localhost:5173/verify-email
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Instagram promotion (event-service)
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.facebook.com/v19.0
INSTAGRAM_GRAPH_API_ACCESS_TOKEN=your-instagram-graph-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id
INSTAGRAM_DEFAULT_IMAGE_URL=https://via.placeholder.com/1080x1080.png?text=Okkazo+Event
INSTAGRAM_DRY_RUN=true
INSTAGRAM_HTTP_TIMEOUT_MS=15000

# WebRTC (chat-service)
ENABLE_CHAT_CALLS=false
WEBRTC_STUN_URL=stun:stun.l.google.com:19302
WEBRTC_TURN_URL=turn:global.relay.metered.ca:80?transport=tcp
WEBRTC_TURN_USERNAME=your-metered-turn-username
WEBRTC_TURN_CREDENTIAL=your-metered-turn-credential
WEBRTC_TURN_REALM=
TURN_EXTERNAL_IP=

# Cloudinary Configuration (Required for file uploads)
# Get your credentials from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
