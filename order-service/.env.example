# Server
PORT=8087
NODE_ENV=development
SERVICE_NAME=order-service
SERVICE_HOST=order-service
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://admin:root@mongodb:27017/okkazo_order_db?authSource=admin

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC=payment_events
KAFKA_CLIENT_ID=order-service

# Eureka
EUREKA_HOST=eureka-server
EUREKA_PORT=8761
EUREKA_REGISTER_WITH_EUREKA=true

# Event Service
EVENT_SERVICE_URL=http://event-service:8086

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Business defaults
DEFAULT_PLATFORM_FEE_INR=15000
