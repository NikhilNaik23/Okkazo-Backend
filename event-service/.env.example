# Environment
NODE_ENV=development

# Server Configuration
PORT=8086
SERVICE_NAME=event-service
SERVICE_HOST=localhost

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/okkazo_event_db
MONGODB_TEST_URI=mongodb://localhost:27017/okkazo_event_db_test

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=event-service
KAFKA_GROUP_ID=event-service-group
KAFKA_TOPIC=event_events
KAFKA_COMMAND_TOPIC=event_commands

# Eureka Configuration
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_INSTANCE_PORT=8086
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=dlyopmrd8
CLOUDINARY_API_KEY=469772985531518
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=okkazo/events

# API Gateway
API_GATEWAY_URL=http://localhost:8080

# Logging
LOG_LEVEL=info
